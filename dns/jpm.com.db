$ORIGIN jpm.com.
@   3600 IN SOA  ns1.jpm.com. admin.jpm.com. (
        2026032101 ; serial
        3600       ; refresh
        900        ; retry
        86400      ; expire
        300        ; minimum
    )

    3600 IN NS   ns1.jpm.com.

ns1                  IN A 127.0.0.1
@                    IN A 127.0.0.1
*                    IN A 127.0.0.1
